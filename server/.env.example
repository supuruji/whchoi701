# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative SMTP providers
# For Outlook: smtp-mail.outlook.com
# For Yahoo: smtp.mail.yahoo.com
# For Naver: smtp.naver.com

# Database Configuration
# SQLite database will be created automatically at server/data/riss_notifications.db

# Crawler Configuration
CRAWLER_INTERVAL_HOURS=6
CRAWLER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Application Settings
APP_NAME="RISS 주역 논문 알림 시스템"
DEFAULT_KEYWORD="주역"